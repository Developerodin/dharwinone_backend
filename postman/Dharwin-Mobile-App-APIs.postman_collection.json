{
  "info": {
    "_postman_id": "dharwin-mobile-app-apis",
    "name": "Dharwin Mobile App APIs",
    "description": "Full backend coverage for the Dharwin mobile app (Mail, Meetings, Files, Calls, Chats, LiveKit). Set email/password in collection variables, run Auth -> Login, then any request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://apis.dharwinone.com/v1", "type": "string" },
    { "key": "email", "value": "your-email@example.com", "type": "string" },
    { "key": "password", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "accountId", "value": "", "type": "string" },
    { "key": "outlookAccountId", "value": "", "type": "string" },
    { "key": "threadId", "value": "", "type": "string" },
    { "key": "messageId", "value": "", "type": "string" },
    { "key": "attachmentId", "value": "", "type": "string" },
    { "key": "labelId", "value": "", "type": "string" },
    { "key": "templateId", "value": "", "type": "string" },
    { "key": "meetingId", "value": "", "type": "string" },
    { "key": "meetingRoomName", "value": "", "type": "string" },
    { "key": "recordingId", "value": "", "type": "string" },
    { "key": "conversationId", "value": "", "type": "string" },
    { "key": "chatMessageId", "value": "", "type": "string" },
    { "key": "fileKey", "value": "", "type": "string" },
    { "key": "folderPrefix", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.tokens) {",
                  "  if (json.tokens.access && json.tokens.access.token) pm.collectionVariables.set('accessToken', json.tokens.access.token);",
                  "  if (json.tokens.refresh && json.tokens.refresh.token) pm.collectionVariables.set('refreshToken', json.tokens.refresh.token);",
                  "  console.log('tokens saved');",
                  "} else {",
                  "  console.warn('No tokens in JSON. Set AUTH_RETURN_TOKENS_IN_JSON=true on the backend for non-prod testing.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me (current user)",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Refresh Tokens",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/refresh-tokens"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "2. Mail - Gmail",
      "item": [
        {
          "name": "GET Accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const r = pm.response.json();",
                  "  const list = Array.isArray(r) ? r : (r.data || []);",
                  "  const a = list[0];",
                  "  const id = a && (a._id || a.id || a.accountId);",
                  "  if (id) { pm.collectionVariables.set('accountId', id); console.log('accountId saved'); }",
                  "}"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/email/accounts" }
        },
        {
          "name": "OAuth - Start Google",
          "request": { "method": "GET", "url": "{{baseUrl}}/email/auth/google" }
        },
        {
          "name": "OAuth - Google Callback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/auth/google/callback?code=&state=",
              "host": ["{{baseUrl}}"],
              "path": ["email", "auth", "google", "callback"],
              "query": [
                { "key": "code", "value": "" },
                { "key": "state", "value": "" }
              ]
            }
          }
        },
        {
          "name": "DELETE Account",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/email/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "accounts", "{{accountId}}"]
            }
          }
        },
        {
          "name": "List Threads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/threads?accountId={{accountId}}&labelId=INBOX&pageSize=25",
              "host": ["{{baseUrl}}"],
              "path": ["email", "threads"],
              "query": [
                { "key": "accountId", "value": "{{accountId}}" },
                { "key": "labelId", "value": "INBOX" },
                { "key": "pageToken", "value": "", "disabled": true },
                { "key": "pageSize", "value": "25" },
                { "key": "q", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Thread Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/threads/{{threadId}}?accountId={{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "threads", "{{threadId}}"],
              "query": [{ "key": "accountId", "value": "{{accountId}}" }]
            }
          }
        },
        {
          "name": "Single Message",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}?accountId={{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}"],
              "query": [{ "key": "accountId", "value": "{{accountId}}" }]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"to\": [\"someone@example.com\"],\n  \"cc\": [],\n  \"bcc\": [],\n  \"subject\": \"Hello from Postman\",\n  \"body\": \"<p>Body HTML</p>\"\n}" },
            "url": "{{baseUrl}}/email/messages/send"
          }
        },
        {
          "name": "Reply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"body\": \"<p>Reply body</p>\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}/reply",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}", "reply"]
            }
          }
        },
        {
          "name": "Reply All",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"body\": \"<p>Reply-all body</p>\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}/reply-all",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}", "reply-all"]
            }
          }
        },
        {
          "name": "Forward",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"to\": [\"forward@example.com\"],\n  \"body\": \"<p>Forwarded</p>\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}/forward",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}", "forward"]
            }
          }
        },
        {
          "name": "Patch Message (labels/read)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"addLabelIds\": [],\n  \"removeLabelIds\": [\"UNREAD\"]\n}" },
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}"]
            }
          }
        },
        {
          "name": "Batch Modify Messages",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"ids\": [\"{{messageId}}\"],\n  \"addLabelIds\": [],\n  \"removeLabelIds\": [\"UNREAD\"]\n}" },
            "url": "{{baseUrl}}/email/messages/batch-modify"
          }
        },
        {
          "name": "Trash Thread",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"threadId\": \"{{threadId}}\"\n}" },
            "url": "{{baseUrl}}/email/threads/trash"
          }
        },
        {
          "name": "Get Attachment",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/messages/{{messageId}}/attachments/{{attachmentId}}?accountId={{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "messages", "{{messageId}}", "attachments", "{{attachmentId}}"],
              "query": [{ "key": "accountId", "value": "{{accountId}}" }]
            }
          }
        },
        {
          "name": "Labels",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/labels?accountId={{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "labels"],
              "query": [{ "key": "accountId", "value": "{{accountId}}" }]
            }
          }
        },
        {
          "name": "Templates - List",
          "request": { "method": "GET", "url": "{{baseUrl}}/email/templates" }
        },
        {
          "name": "Templates - Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Welcome\",\n  \"subject\": \"Hi\",\n  \"body\": \"<p>Hello</p>\"\n}" },
            "url": "{{baseUrl}}/email/templates"
          }
        },
        {
          "name": "Templates - Patch",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"subject\": \"Updated\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/email/templates/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["email", "templates", "{{templateId}}"]
            }
          }
        },
        {
          "name": "Signature - Get",
          "request": { "method": "GET", "url": "{{baseUrl}}/email/signature" }
        },
        {
          "name": "Signature - Patch",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"signature\": \"<p>--<br/>Name</p>\"\n}" },
            "url": "{{baseUrl}}/email/signature"
          }
        },
        {
          "name": "Drafts - AI Generate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"prompt\": \"Draft a polite follow-up\",\n  \"context\": {}\n}" },
            "url": "{{baseUrl}}/email/drafts/generate"
          }
        }
      ]
    },
