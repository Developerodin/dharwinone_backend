          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}"]
            }
          }
        },
        {
          "name": "Resend Invites",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}/resend-invitations",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}", "resend-invitations"]
            }
          }
        },
        {
          "name": "Recordings for Meeting",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}/recordings",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}", "recordings"]
            }
          }
        }
      ]
    },
    {
      "name": "5. LiveKit",
      "item": [
        {
          "name": "Token - Meeting",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roomName\": \"{{meetingRoomName}}\",\n  \"participantName\": \"Test User\",\n  \"participantEmail\": \"{{email}}\"\n}" },
            "url": "{{baseUrl}}/livekit/token"
          }
        },
        {
          "name": "Token - Chat Call",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roomName\": \"{{conversationId}}\",\n  \"participantName\": \"Test User\",\n  \"participantEmail\": \"{{email}}\",\n  \"forChatCall\": true\n}" },
            "url": "{{baseUrl}}/livekit/token"
          }
        },
        {
          "name": "Recording - Start",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roomName\": \"{{meetingRoomName}}\"\n}" },
            "url": "{{baseUrl}}/livekit/recording/start"
          }
        },
        {
          "name": "Recording - Stop",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roomName\": \"{{meetingRoomName}}\"\n}" },
            "url": "{{baseUrl}}/livekit/recording/stop"
          }
        },
        {
          "name": "Recording - Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/livekit/recording/status/{{meetingRoomName}}",
              "host": ["{{baseUrl}}"],
              "path": ["livekit", "recording", "status", "{{meetingRoomName}}"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Recordings (Global)",
      "item": [
        {
          "name": "List Recordings",
          "request": { "method": "GET", "url": "{{baseUrl}}/recordings" }
        },
        {
          "name": "Recording Transcript",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/recordings/{{recordingId}}/transcript",
              "host": ["{{baseUrl}}"],
              "path": ["recordings", "{{recordingId}}", "transcript"]
            }
          }
        }
      ]
    },
    {
      "name": "7. File Storage",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/file-storage/list?prefix=&maxKeys=50",
              "host": ["{{baseUrl}}"],
              "path": ["file-storage", "list"],
              "query": [
                { "key": "prefix", "value": "" },
                { "key": "next", "value": "", "disabled": true },
                { "key": "maxKeys", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Download (signed URL)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/file-storage/download?key={{fileKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["file-storage", "download"],
              "query": [{ "key": "key", "value": "{{fileKey}}" }]
            }
          }
        },
        {
          "name": "Upload (multipart)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] },
                { "key": "folder", "value": "{{folderPrefix}}", "type": "text", "disabled": true }
              ]
            },
            "url": "{{baseUrl}}/file-storage/upload",
            "description": "Max 20 MB. Field name = file."
          }
        },
        {
          "name": "Delete Object",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/file-storage/object?key={{fileKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["file-storage", "object"],
              "query": [{ "key": "key", "value": "{{fileKey}}" }]
            }
          }
        },
        {
          "name": "Create Folder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"NewFolder\",\n  \"prefix\": \"{{folderPrefix}}\"\n}" },
            "url": "{{baseUrl}}/file-storage/folder"
          }
        }
      ]
    },
    {
      "name": "8. Chats",
      "item": [
        {
          "name": "List Conversations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const r = pm.response.json();",
                  "  const list = Array.isArray(r) ? r : (r.data || r.conversations || []);",
                  "  const c = list[0];",
                  "  const id = c && (c._id || c.id);",
                  "  if (id) pm.collectionVariables.set('conversationId', id);",
                  "}"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/chats/conversations" }
        },
        {
          "name": "Conversation Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}"]
            }
          }
        },
        {
          "name": "Messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}", "messages"]
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Hello from Postman\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}", "messages"]
            }
          }
        },
        {
          "name": "Send Message with File",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "text", "value": "Attaching file", "type": "text" },
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}/messages/upload",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}", "messages", "upload"]
            }
          }
        },
        {
          "name": "Mark Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}", "read"]
            }
          }
        },
        {
          "name": "Start Call",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"audio\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/chats/conversations/{{conversationId}}/call",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "conversations", "{{conversationId}}", "call"]
            }
          }
        },
        {
          "name": "Socket Token",
          "request": { "method": "GET", "url": "{{baseUrl}}/chats/socket-token" }
        },
        {
          "name": "User Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chats/users/search?search=",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "users", "search"],
              "query": [{ "key": "search", "value": "", "description": "Backend param is 'search' (not 'q')" }]
            }
          }
        },
        {
          "name": "In-App Calls List",
          "request": { "method": "GET", "url": "{{baseUrl}}/chats/calls" }
        }
      ]
