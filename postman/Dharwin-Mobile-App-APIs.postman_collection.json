    {
      "name": "4. Internal Meetings",
      "item": [
        {
          "name": "List - Upcoming",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings?status=scheduled&page=1&limit=25&sortBy=startTime&order=asc",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings"],
              "query": [
                { "key": "status", "value": "scheduled", "description": "scheduled|ended|cancelled" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "sortBy", "value": "startTime" },
                { "key": "order", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "List - Completed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings?status=ended&page=1&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings"],
              "query": [
                { "key": "status", "value": "ended" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "List - Cancelled",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings?status=cancelled&page=1&limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings"],
              "query": [
                { "key": "status", "value": "cancelled" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  const m = j.data || j;",
                  "  if (m && m.meetingId) pm.collectionVariables.set('meetingRoomName', m.meetingId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}"]
            }
          }
        },
        {
          "name": "Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const j = pm.response.json();",
                  "  const m = j.data || j;",
                  "  if (m && (m._id || m.id)) pm.collectionVariables.set('meetingId', m._id || m.id);",
                  "  if (m && m.meetingId) pm.collectionVariables.set('meetingRoomName', m.meetingId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Team Sync\",\n  \"description\": \"Weekly sync\",\n  \"startTime\": \"2026-05-28T10:00:00.000Z\",\n  \"endTime\": \"2026-05-28T10:30:00.000Z\",\n  \"timezone\": \"Asia/Kolkata\",\n  \"participants\": [\n    { \"email\": \"someone@example.com\", \"name\": \"Someone\" }\n  ],\n  \"sendInvites\": true\n}" },
            "url": "{{baseUrl}}/internal-meetings"
          }
        },
        {
          "name": "Patch / Reschedule",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Renamed\",\n  \"startTime\": \"2026-05-28T11:00:00.000Z\",\n  \"endTime\": \"2026-05-28T11:30:00.000Z\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}"]
            }
          }
        },
        {
          "name": "Cancel (PATCH status)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"cancelled\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/internal-meetings/{{meetingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["internal-meetings", "{{meetingId}}"]
            }
          }
        },
