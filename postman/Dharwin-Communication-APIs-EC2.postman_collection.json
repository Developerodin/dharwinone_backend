{
  "info": {
    "_postman_id": "dharwin-communication-apis-ec2",
    "name": "Dharwin Communication APIs - EC2",
    "description": "EC2/prod-ready collection. Set email/password in collection variables, run Auth Bootstrap -> Login, then other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://apis.dharwinone.com/v1",
      "type": "string"
    },
    {
      "key": "email",
      "value": "your-email@example.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "accountId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth Bootstrap",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.tokens && json.tokens.access && json.tokens.access.token) {",
                  "  pm.collectionVariables.set('accessToken', json.tokens.access.token);",
                  "  if (pm.environment && pm.environment.name) {",
                  "    pm.environment.set('accessToken', json.tokens.access.token);",
                  "  }",
                  "  console.log('accessToken saved');",
                  "} else {",
                  "  console.warn('No tokens in JSON. Set AUTH_RETURN_TOKENS_IN_JSON=true in backend .env if testing a non-production backend.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Communication - Unified Calls",
      "item": [
        {
          "name": "GET All Calls",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/communication/calls?page=1&limit=10&sortBy=createdAt&order=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "communication",
                "calls"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Page size (default 25, max 500)"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "description": "createdAt or date - NOT createdAt:desc"
                },
                {
                  "key": "order",
                  "value": "desc",
                  "description": "asc or desc"
                },
                {
                  "key": "source",
                  "value": "all",
                  "description": "all | telephony | in_app",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "purpose",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "language",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Chats & Calls",
      "item": [
        {
          "name": "GET Conversations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats/conversations"
          }
        },
        {
          "name": "GET In-App Calls",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chats/calls"
          }
        }
      ]
    },
    {
      "name": "Email - Gmail",
      "item": [
        {
          "name": "GET Gmail Accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const accounts = pm.response.json();",
                  "  const firstAccount = Array.isArray(accounts) ? accounts[0] : null;",
                  "  const accountId = firstAccount && (firstAccount._id || firstAccount.id || firstAccount.accountId);",
                  "  if (accountId) {",
                  "    pm.collectionVariables.set('accountId', accountId);",
                  "    if (pm.environment && pm.environment.name) {",
                  "      pm.environment.set('accountId', accountId);",
                  "    }",
                  "    console.log('accountId saved');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/email/accounts"
          }
        },
        {
          "name": "GET Gmail Messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/email/messages?accountId={{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "email",
                "messages"
              ],
              "query": [
                {
                  "key": "accountId",
                  "value": "{{accountId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Email - Outlook",
      "item": [
        {
          "name": "GET Outlook Accounts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/outlook/accounts"
          }
        }
      ]
    },
    {
      "name": "Recordings & Meetings",
      "item": [
        {
          "name": "GET Meetings (placeholder)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/meetings",
            "description": "Adjust path/query per your meeting routes."
          }
        }
      ]
    }
  ]
}
